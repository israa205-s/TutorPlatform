l_filter/></table><table schema="main" name="student" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="69"/><column index="2" value="52"/><column index="3" value="61"/><column index="4" value="108"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="tutor" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="54"/><column index="2" value="52"/><column index="3" value="300"/><column index="4" value="86"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="users" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="50"/><column index="2" value="255"/><column index="3" value="300"/><column index="4" value="63"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">-- ====================================================================
-- 1. DATABASE STRUCTURE (DDL)
-- Bunlar veritabanının iskeletidir
-- ====================================================================

CREATE TABLE major (
    major_id INTEGER PRIMARY KEY,
    major_name TEXT NOT NULL UNIQUE
);

CREATE TABLE users (
    user_id INTEGER PRIMARY KEY,
    email TEXT NOT NULL UNIQUE,
    password TEXT NOT NULL,
    role_type TEXT CHECK (role_type IN ('student', 'tutor'))
);

CREATE TABLE student (
    student_id INTEGER PRIMARY KEY,
    user_id INTEGER NOT NULL,
    major_id INTEGER NOT NULL,
    registration_date TEXT DEFAULT CURRENT_DATE,
    FOREIGN KEY (user_id) REFERENCES users(user_id),
    FOREIGN KEY (major_id) REFERENCES major(major_id)
);

CREATE TABLE tutor (
    tutor_id INTEGER PRIMARY KEY,
    user_id INTEGER NOT NULL,
    bio TEXT,
    average_rate REAL DEFAULT 0.0,
    FOREIGN KEY (user_id) REFERENCES users(user_id)
);

CREATE TABLE subject (
    subject_id INTEGER PRIMARY KEY,
    subject_name TEXT NOT NULL,
    major_id INTEGER NOT NULL,
    FOREIGN KEY (major_id) REFERENCES major(major_id)
);

CREATE TABLE session (
    session_id INTEGER PRIMARY KEY,
    tutor_id INTEGER NOT NULL,
    session_date TEXT NOT NULL,
    start_time TEXT NOT NULL,
    status TEXT DEFAULT 'available',
    FOREIGN KEY (tutor_id) REFERENCES tutor(tutor_id)
);

CREATE TABLE booking (
    booking_id INTEGER PRIMARY KEY,
    student_id INTEGER NOT NULL,
    session_id INTEGER NOT NULL UNIQUE,
    booking_date TEXT DEFAULT CURRENT_TIMESTAMP,
    status TEXT DEFAULT 'pending',
    FOREIGN KEY (student_id) REFERENCES student(student_id),
    FOREIGN KEY (session_id) REFERENCES session(session_id)
);

-- ====================================================================
-- 2. INITIAL SEED DATA
-- Sadece sitenin açılması için zorunlu olan temel veriler
-- Kullanıcı ve randevu gibi dinamik veriler yok
-- ====================================================================

INSERT INTO major (major_id, major_name) VALUES 
(1, 'Computer Science'), 
(2, 'Mathematics'),
(3, 'Physics'),
(4, 'Business Administration');
INSERT INTO major (major_name) VALUES ('Database Management Systems');
INSERT INTO major (major_name) VALUES ('Internet Based Programming');

--SELECT * FROM major WHERE major_name LIKE '%Management%';
--kendimi ögrenci olarak kaydediyorum
INSERT INTO student (user_id, major_id) 
SELECT user_id, 1 FROM users WHERE email = '7zuleyahulaas@gmail.com';


-- Hoca 1'i eğitmen tablosuna bağlıyoruz (Alt sorgu kullanarak)
INSERT INTO tutor (user_id, bio) 
SELECT user_id, 'Internet Based Programming' 
FROM users WHERE email = 'meleksenturk@karabuk.edu.tr';

-- Hoca 2'yi eğitmen tablosuna bağlıyoruz
INSERT INTO tutor (user_id, bio) 
SELECT user_id, 'Database Management Systems' 
FROM users WHERE email = 'simgekaplan@karabuk.edu.tr';

-- Hoca 1 için bir ders saati ekle
INSERT INTO session (tutor_id, session_date, start_time, status)
VALUES (1, '2026-05-25', '14:00', 'available');

-- Hoca 2 için bir ders saati ekle
INSERT INTO session (tutor_id, session_date, start_time, status)
VALUES (2, '2026-05-26', '10:30', 'available');


ALTER TABLE tutor ADD COLUMN major_id INTEGER;

-- Örnek: 1 numaralı hocayı 1 numaralı bölüme (Computer Science) atıyoruz

UPDATE tutor SET major_id = 6 WHERE tutor_id = 1;

UPDATE tutor SET major_id = 5 WHERE tutor_id = 2;

